# Embedded dashboard build output — generated by `make build` (frontend → dist).
# We keep a .gitkeep so `go:embed all:dist` always compiles; the actual built
# assets are produced at build time and never committed (they're content-hashed
# and change every build).
internal/web/dist/*
!internal/web/dist/.gitkeep

# compress-bench harness binary (built ad-hoc, never commit)
/compress-bench
cmd/compress-bench/compress-bench
rebake-evidence.json
