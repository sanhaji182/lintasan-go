{{define "components/empty.gohtml"}}
<div class="empty-state">
  <div class="empty-state-icon">{{.Icon}}</div>
  <p style="font-size:14px; margin-bottom:4px;">{{.Message}}</p>
  {{if .Action}}
  <button class="btn btn-primary" style="margin-top:12px;" {{if .ActionHxGet}}hx-get="{{.ActionHxGet}}"{{end}} {{if .ActionOnClick}}x-on:click="{{.ActionOnClick}}"{{end}}>{{.Action}}</button>
  {{end}}
</div>
{{end}}
