<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Lintasan — {{.PageTitle}}</title>
<link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><rect width='100' height='100' rx='20' fill='%233c50e0'/><text x='50' y='72' text-anchor='middle' fill='white' font-size='52' font-weight='700' font-family='system-ui'>L</text></svg>">
<style>
/* ===== Ocean Theme CSS (Node.js parity) ===== */
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --font:'Inter',system-ui,-apple-system,sans-serif;
  --mono:'JetBrains Mono',ui-monospace,monospace;
  --bg-body:#0f1419;
  --bg-card:#1a2332;
  --bg-sidebar:#111827;
  --bg-sidebar-hover:#1f2937;
  --fg-sidebar:#e2e8f0;
  --fg-sidebar-muted:#64748b;
  --sidebar-border:#1e293b;
  --sidebar-logo-text:#f1f5f9;
  --fg-0:#f1f5f9;
  --fg-1:#cbd5e1;
  --fg-2:#94a3b8;
  --fg-3:#64748b;
  --border:#1e293b;
  --border-light:#1e293b;
  --primary:#3c50e0;
  --primary-hover:#4f63e8;
  --primary-glow:rgba(60,80,224,0.2);
  --primary-light:rgba(60,80,224,0.12);
  --success:#10b981;
  --success-light:rgba(16,185,129,0.12);
  --warning:#f59e0b;
  --warning-light:rgba(245,158,11,0.12);
  --error:#ef4444;
  --error-light:rgba(239,68,68,0.12);
  --info:#3b82f6;
  --info-light:rgba(59,130,246,0.12);
  --purple:#8b5cf6;
  --purple-light:rgba(139,92,246,0.12);
  --shadow-sm:0 1px 2px rgba(0,0,0,0.3);
  --shadow:0 2px 8px rgba(0,0,0,0.4);
  --shadow-md:0 8px 24px rgba(0,0,0,0.5);
  --shadow-lg:0 16px 48px rgba(0,0,0,0.6);
  --radius:12px;
  --radius-sm:8px;
  --radius-lg:16px;
  --transition:0.2s cubic-bezier(0.4,0,0.2,1);
}
[data-theme="light"]{
  --bg-body:#f1f5f9;
  --bg-card:#ffffff;
  --bg-sidebar:#ffffff;
  --bg-sidebar-hover:#f1f5f9;
  --fg-sidebar:#334155;
  --fg-sidebar-muted:#94a3b8;
  --sidebar-border:#e2e8f0;
  --sidebar-logo-text:#1e293b;
  --fg-0:#1e293b;
  --fg-1:#334155;
  --fg-2:#64748b;
  --fg-3:#94a3b8;
  --border:#e2e8f0;
  --border-light:#f1f5f9;
  --primary-light:rgba(60,80,224,0.08);
  --success-light:#ecfdf5;
  --warning-light:#fffbeb;
  --error-light:#fef2f2;
  --info-light:#eff6ff;
  --purple-light:#f5f3ff;
  --shadow-sm:0 1px 2px rgba(0,0,0,0.04);
  --shadow:0 2px 8px rgba(0,0,0,0.06);
  --shadow-md:0 8px 24px rgba(0,0,0,0.08);
  --shadow-lg:0 16px 48px rgba(0,0,0,0.1);
}
body{font-family:var(--font);background:var(--bg-body);color:var(--fg-0);-webkit-font-smoothing:antialiased;line-height:1.6;overflow-x:hidden}
[x-cloak]{display:none!important}
input,select,textarea,button{font-family:var(--font)}
::selection{background:var(--primary);color:#fff}
::-webkit-scrollbar{width:6px;height:6px}
::-webkit-scrollbar-track{background:transparent}
::-webkit-scrollbar-thumb{background:var(--border);border-radius:3px}
::-webkit-scrollbar-thumb:hover{background:var(--fg-3)}
@keyframes fadeInUp{from{opacity:0;transform:translateY(16px)}to{opacity:1;transform:none}}
@keyframes fadeInScale{from{opacity:0;transform:scale(0.95)}to{opacity:1;transform:none}}
@keyframes shimmer{0%{background-position:-200% 0}100%{background-position:200% 0}}
@keyframes spin{to{transform:rotate(360deg)}}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:0.5}}
@keyframes glow{0%,100%{box-shadow:0 0 4px var(--primary-glow)}50%{box-shadow:0 0 16px var(--primary-glow)}}
@keyframes dotPulse{0%,100%{transform:scale(1);opacity:1}50%{transform:scale(1.4);opacity:0.7}}
@keyframes float{0%,100%{transform:translateY(0)}50%{transform:translateY(-4px)}}
.fade-in{animation:fadeInUp 0.4s ease-out both}
.fade-in-scale{animation:fadeInScale 0.25s ease-out both}
.modal-backdrop{position:fixed;inset:0;background:rgba(0,0,0,.6);z-index:40;animation:fadeInScale .2s ease-out}
.modal-panel{background:var(--bg-card);border-radius:var(--radius-lg);z-index:50;width:90%;max-width:480px;max-height:80vh;padding:24px;position:fixed;top:10%;left:50%;overflow-y:auto;transform:translate(-50%);box-shadow:var(--shadow-lg);animation:fadeInScale .25s ease-out}
.skeleton{background:linear-gradient(90deg,var(--border-light) 25%,var(--border) 50%,var(--border-light) 75%);background-size:200% 100%;animation:shimmer 1.5s infinite;border-radius:var(--radius-sm)}
.card{background:var(--bg-card);border-radius:var(--radius);padding:20px;box-shadow:var(--shadow);border:1px solid var(--border)}
.btn-primary{display:inline-flex;align-items:center;gap:6px;padding:8px 16px;background:var(--primary);color:#fff;border:none;border-radius:var(--radius-sm);font-size:13px;font-weight:500;cursor:pointer;transition:all 0.15s ease}
.btn-primary:hover{background:var(--primary-hover)}
.btn-secondary{display:inline-flex;align-items:center;gap:6px;padding:8px 16px;background:var(--bg-body);color:var(--fg-1);border:1px solid var(--border);border-radius:var(--radius-sm);font-size:13px;font-weight:500;cursor:pointer;transition:all 0.15s ease}
.btn-danger{display:flex;align-items:center;justify-content:center;width:30px;height:30px;background:none;border:1px solid var(--border);border-radius:6px;color:var(--error);cursor:pointer;transition:all 0.15s ease}
.btn-small{padding:5px 12px;background:var(--bg-body);color:var(--fg-1);border:1px solid var(--border);border-radius:4px;font-size:11px;font-weight:500;cursor:pointer}
.input-field{width:100%;padding:9px 12px;background:var(--bg-body);border:1px solid var(--border);border-radius:6px;color:var(--fg-0);font-size:13px;outline:none;transition:border-color 0.15s}
.input-field:focus{border-color:var(--primary)}
table{width:100%;border-collapse:collapse;font-size:13px}
th{text-align:left;padding:12px 16px;font-weight:500;color:var(--fg-3);font-size:11px;border-bottom:1px solid var(--border);text-transform:uppercase;letter-spacing:0.5px}
td{padding:14px 16px;vertical-align:middle}
tr{border-bottom:1px solid var(--border);transition:background 0.1s}
tr:hover{background:var(--bg-body)}
.label-st{display:block;font-size:12px;color:var(--fg-2);margin-bottom:6px;font-weight:500}
.mono{font-family:var(--mono);font-size:12px;color:var(--fg-2);background:var(--bg-body);padding:3px 8px;border-radius:4px}
.stat-card{background:var(--bg-card);border-radius:var(--radius);padding:16px 20px;box-shadow:var(--shadow);border:1px solid var(--border)}
.stat-label{font-size:11px;color:var(--fg-3);margin-bottom:4px;text-transform:uppercase;letter-spacing:0.5px;font-weight:500}
.stat-value{font-size:22px;font-weight:700;color:var(--fg-0);font-family:var(--mono);letter-spacing:-0.5px}
.status-badge{font-size:11px;padding:4px 10px;border-radius:9999px;font-weight:600}
.badge-success{background:var(--success-light);color:var(--success)}
.badge-warning{background:var(--warning-light);color:var(--warning)}
.badge-error{background:var(--error-light);color:var(--error)}
.badge-primary{background:var(--primary-light);color:var(--primary)}
.badge-info{background:var(--info-light);color:var(--info)}
.empty-state{padding:48px;text-align:center}
.toast{position:fixed;bottom:24px;right:24px;padding:12px 20px;border-radius:var(--radius-sm);font-size:13px;font-weight:500;z-index:1000;animation:fadeInUp 0.3s ease;box-shadow:var(--shadow-md)}
.toast-success{background:var(--success);color:#fff}
.toast-error{background:var(--error);color:#fff}

@media(max-width:768px){
  #sidebar{transform:translateX(-100%);transition:transform 0.3s ease}
  #sidebar.open{transform:translateX(0)}
  #main-area{margin-left:0!important}
  .stat-grid-4{grid-template-columns:repeat(2,1fr)!important;gap:12px!important}
  .chart-grid{grid-template-columns:1fr!important}
}
</style>
<script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
<script src="https://unpkg.com/htmx.org@1.9.12"></script>
<script src="/static/app.js"></script>
</head>
<body>
<div style="display:flex;min-height:100vh">
  <!-- Sidebar -->
  <aside id="sidebar" style="width:260px;min-height:100vh;background:var(--bg-sidebar);display:flex;flex-direction:column;position:fixed;left:0;top:0;bottom:0;overflow-y:auto;z-index:50;border-right:1px solid var(--sidebar-border);box-shadow:var(--shadow-sm);transition:transform 0.3s ease">
    <div style="padding:20px 16px;display:flex;align-items:center;gap:12px;border-bottom:1px solid var(--sidebar-border)">
      <div style="width:36px;height:36px;border-radius:10px;background:linear-gradient(135deg,var(--primary) 0%,#6366f1 100%);display:flex;align-items:center;justify-content:center;box-shadow:0 4px 12px var(--primary-glow);flex-shrink:0">
        <span style="color:#fff;font-size:16px;font-weight:700">L</span>
      </div>
      <div>
        <h2 style="font-size:14px;font-weight:700;color:var(--sidebar-logo-text);letter-spacing:-0.2px">Lintasan</h2>
        <p style="font-size:11px;color:var(--fg-sidebar-muted);font-family:var(--mono)">v2.0.0</p>
      </div>
    </div>
    <nav style="flex:1;padding:12px 10px">
      {{range .NavGroups}}
      <div style="margin-bottom:20px">
        <p style="font-size:10px;font-weight:600;color:var(--fg-sidebar-muted);padding:0 10px;margin-bottom:6px;letter-spacing:0.8px;text-transform:uppercase">{{.Title}}</p>
        {{range .Items}}
        <a href="{{.Path}}" hx-get="{{.Path}}" hx-target="#page-content" hx-push-url="true" hx-swap="innerHTML"
           style="display:flex;align-items:center;gap:10px;padding:10px 12px;border-radius:var(--radius-sm);font-size:13px;font-weight:500;color:var(--fg-sidebar);cursor:pointer;margin-bottom:2px;text-decoration:none;transition:all 0.15s ease;border-left:3px solid transparent"
           onmouseover="this.style.background='var(--bg-sidebar-hover)'" onmouseout="if(!this.classList.contains('active'))this.style.background='transparent'"
           onclick="document.querySelectorAll('#sidebar a').forEach(a=>{a.classList.remove('active');a.style.color='var(--fg-sidebar)';a.style.background='transparent';a.style.fontWeight='500';a.style.borderLeftColor='transparent'});this.classList.add('active');this.style.color='var(--primary)';this.style.background='var(--primary-light)';this.style.fontWeight='600';this.style.borderLeftColor='var(--primary)'">
          <span style="opacity:0.7;display:flex">{{.SVG}}</span>
          {{.Label}}
        </a>
        {{end}}
      </div>
      {{end}}
    </nav>
    <div style="padding:12px 16px;border-top:1px solid var(--sidebar-border)">
      <button onclick="toggleTheme()" style="width:100%;padding:10px 12px;background:var(--bg-sidebar-hover);border:1px solid var(--sidebar-border);border-radius:var(--radius-sm);color:var(--fg-sidebar);font-size:13px;cursor:pointer;font-weight:500;display:flex;align-items:center;justify-content:center;gap:8px;min-height:44px">
        <span id="theme-icon"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg></span>
        <span id="theme-label">Light Mode</span>
      </button>
    </div>
  </aside>

  <!-- Backdrop -->
  <div id="sidebar-backdrop" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.5);z-index:49;opacity:0;transition:opacity 0.3s" onclick="closeSidebar()"></div>

  <!-- Main -->
  <div style="flex:1;margin-left:260px" id="main-area">
    <!-- Header -->
    <header style="height:60px;background:var(--bg-card);border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;padding:0 24px;position:sticky;top:0;z-index:40;backdrop-filter:blur(12px)">
      <div style="display:flex;align-items:center;gap:12px">
        <button class="hamburger-btn" onclick="toggleSidebar()" style="display:none;align-items:center;justify-content:center;width:44px;height:44px;border:none;background:transparent;cursor:pointer;border-radius:var(--radius-sm);color:var(--fg-0)" id="hamburger">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
        </button>
        <span style="font-size:15px;font-weight:600;color:var(--fg-0)">{{.PageTitle}}</span>
      </div>
      <div style="display:flex;align-items:center;gap:14px">
        <div style="display:flex;align-items:center;gap:6px;background:var(--bg-body);padding:5px 10px;border-radius:var(--radius-sm);border:1px solid var(--border)">
          <div style="width:6px;height:6px;border-radius:50%;background:var(--success);animation:dotPulse 2s infinite"></div>
          <span style="font-size:12px;color:var(--fg-2);font-family:var(--mono)">Port 20181</span>
        </div>
        <div style="width:32px;height:32px;border-radius:50%;background:linear-gradient(135deg,var(--primary) 0%,#6366f1 100%);display:flex;align-items:center;justify-content:center;cursor:pointer" title="Admin">
          <span style="color:#fff;font-size:12px;font-weight:600">SR</span>
        </div>
      </div>
    </header>
    <main id="page-content" style="padding:24px">
      {{.Content}}
    </main>
  </div>
</div>

<script>
var sidebarOpen = false;
var theme = localStorage.getItem('sr-theme') || 'dark';
document.documentElement.setAttribute('data-theme', theme);
updateThemeUI();

function toggleTheme() {
  theme = theme === 'dark' ? 'light' : 'dark';
  localStorage.setItem('sr-theme', theme);
  document.documentElement.setAttribute('data-theme', theme);
  updateThemeUI();
}

function updateThemeUI() {
  var icon = document.getElementById('theme-icon');
  var label = document.getElementById('theme-label');
  if (theme === 'dark') {
    icon.innerHTML = '<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>';
    label.textContent = 'Light Mode';
  } else {
    icon.innerHTML = '<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>';
    label.textContent = 'Dark Mode';
  }
}

function toggleSidebar() {
  sidebarOpen = !sidebarOpen;
  var sidebar = document.getElementById('sidebar');
  var backdrop = document.getElementById('sidebar-backdrop');
  if (sidebarOpen) {
    sidebar.classList.add('open');
    backdrop.style.display = 'block';
    setTimeout(function(){ backdrop.style.opacity = '1'; }, 10);
  } else {
    sidebar.classList.remove('open');
    backdrop.style.opacity = '0';
    setTimeout(function(){ backdrop.style.display = 'none'; }, 300);
  }
}

function closeSidebar() {
  sidebarOpen = false;
  document.getElementById('sidebar').classList.remove('open');
  var backdrop = document.getElementById('sidebar-backdrop');
  backdrop.style.opacity = '0';
  setTimeout(function(){ backdrop.style.display = 'none'; }, 300);
}

// Mark active nav item
document.addEventListener('htmx:afterSettle', function() {
  // Re-init Alpine on swapped content (HTMX swaps #page-content)
  var page = document.getElementById('page-content');
  if (page && window.Alpine) {
    Alpine.initTree(page);
  }
  // Clean up any stale Chart.js instances from previous page
  if (window.Chart) {
    Object.keys(Chart.instances).forEach(function(id) {
      Chart.instances[id].destroy();
    });
  }
  var path = window.location.pathname;

  // Update header + title from swapped content
  var h1 = page && page.querySelector('h1');
  if (h1) {
    var label = h1.textContent.trim();
    var headerTitle = document.querySelector('#main-area header span');
    if (headerTitle) headerTitle.textContent = label;
    document.title = 'Lintasan \u2014 ' + label;
  }

  document.querySelectorAll('#sidebar a').forEach(function(a) {
    a.classList.remove('active');
    a.style.color = 'var(--fg-sidebar)';
    a.style.background = 'transparent';
    a.style.fontWeight = '500';
    a.style.borderLeftColor = 'transparent';
    var href = a.getAttribute('href');
    if (href === path || (path === '/dashboard/' && href === '/dashboard')) {
      a.classList.add('active');
      a.style.color = 'var(--primary)';
      a.style.background = 'var(--primary-light)';
      a.style.fontWeight = '600';
      a.style.borderLeftColor = 'var(--primary)';
    }
  });
});

document.addEventListener('DOMContentLoaded', function() {
  var path = window.location.pathname;
  document.querySelectorAll('#sidebar a').forEach(function(a) {
    var href = a.getAttribute('href');
    if (href === path || (path.endsWith('/') && href === path.slice(0,-1))) {
      a.classList.add('active');
      a.style.color = 'var(--primary)';
      a.style.background = 'var(--primary-light)';
      a.style.fontWeight = '600';
      a.style.borderLeftColor = 'var(--primary)';
    }
  });

  // Show hamburger on mobile
  if (window.innerWidth <= 768) {
    document.getElementById('hamburger').style.display = 'flex';
  }
});
</script>
</body>
</html>
