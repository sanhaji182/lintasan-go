{{define "pages/docs.gohtml"}}
<div>
  <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:20px">
    <div>
      <h1 style="font-size:20px;font-weight:700;color:var(--fg-0);margin:0 0 4px;display:flex;align-items:center;gap:8px">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
        Documentation
      </h1>
      <p style="font-size:13px;color:var(--fg-2);margin:0">Learn how to use Lintasan for AI model routing and management.</p>
    </div>
  </div>

  <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:24px">
    <!-- Sidebar nav -->
    <div style="grid-column:span 1">
      <nav class="card" style="padding:12px">
        <a href="#getting-started" style="display:block;padding:4px 0;font-size:13px;color:var(--fg-2);text-decoration:none">Getting Started</a>
        <a href="#configuration" style="display:block;padding:4px 0;font-size:13px;color:var(--fg-2);text-decoration:none">Configuration</a>
        <a href="#api-reference" style="display:block;padding:4px 0;font-size:13px;color:var(--fg-2);text-decoration:none">API Reference</a>
        <a href="#routing" style="display:block;padding:4px 0;font-size:13px;color:var(--fg-2);text-decoration:none">Routing</a>
        <a href="#fallback" style="display:block;padding:4px 0;font-size:13px;color:var(--fg-2);text-decoration:none">Fallback Chains</a>
        <a href="#caching" style="display:block;padding:4px 0;font-size:13px;color:var(--fg-2);text-decoration:none">Caching</a>
      </nav>
    </div>

    <!-- Content -->
    <div style="grid-column:span 3">
      <section id="getting-started" class="card" style="margin-bottom:16px">
        <h2 style="font-size:13px;font-weight:600;color:var(--fg-1);margin-bottom:12px">Getting Started</h2>
        <p style="font-size:13px;color:var(--fg-2);margin-bottom:12px">Lintasan is a lightweight AI model gateway that routes requests across multiple providers. It supports OpenAI, Anthropic, Google, Groq, Ollama, and any OpenAI-compatible endpoint.</p>
        <h3 style="font-size:12px;font-weight:600;color:var(--fg-1);margin-bottom:8px">Quick Start</h3>
        <pre style="background:var(--color-bg-input);padding:12px;border-radius:var(--radius);font-size:12px;font-family:var(--mono);overflow-x:auto"><code># Set your master key
export LINTASAN_MASTER_KEY="your-secret-key"

# Run the server
./lintasan-go

# Access dashboard at http://localhost:8080/dashboard</code></pre>
      </section>

      <section id="configuration" class="card" style="margin-bottom:16px">
        <h2 style="font-size:13px;font-weight:600;color:var(--fg-1);margin-bottom:12px">Configuration</h2>
        <p style="font-size:13px;color:var(--fg-2);margin-bottom:12px">All configuration is done through the dashboard UI. No config files needed. Settings are stored in SQLite and persist across restarts.</p>
        <ul style="font-size:13px;color:var(--fg-2);list-style:disc;padding-left:20px;display:flex;flex-direction:column;gap:4px">
          <li><strong>Master Key:</strong> Protects your dashboard and API.</li>
          <li><strong>Cache TTL:</strong> How long responses are cached.</li>
          <li><strong>Rate Limits:</strong> Per-key and per-model limits.</li>
        </ul>
      </section>

      <section id="api-reference" class="card" style="margin-bottom:16px">
        <h2 style="font-size:13px;font-weight:600;color:var(--fg-1);margin-bottom:12px">API Reference</h2>
        <p style="font-size:13px;color:var(--fg-2);margin-bottom:12px">Lintasan exposes an OpenAI-compatible API at <code>/v1/chat/completions</code>. Use your API key in the <code>Authorization: Bearer</code> header.</p>
        <pre style="background:var(--color-bg-input);padding:12px;border-radius:var(--radius);font-size:12px;font-family:var(--mono);overflow-x:auto"><code>curl http://localhost:8080/v1/chat/completions \
  -H "Authorization: Bearer *** \
  -H "Content-Type: application/json" \
  -d '{"model":"gpt-4o","messages":[{"role":"user","content":"Hello"}]}'</code></pre>
      </section>

      <section id="routing" class="card" style="margin-bottom:16px">
        <h2 style="font-size:13px;font-weight:600;color:var(--fg-1);margin-bottom:12px">Routing</h2>
        <p style="font-size:13px;color:var(--fg-2)">Configure routing priorities to control which provider handles requests for each model. Higher priority providers are tried first. Use the Routing page to drag and drop provider order.</p>
      </section>

      <section id="fallback" class="card" style="margin-bottom:16px">
        <h2 style="font-size:13px;font-weight:600;color:var(--fg-1);margin-bottom:12px">Fallback Chains</h2>
        <p style="font-size:13px;color:var(--fg-2)">Fallback chains define a sequence of providers to try when the primary provider fails. Create chains that step through providers in order until one succeeds.</p>
      </section>

      <section id="caching" class="card" style="margin-bottom:16px">
        <h2 style="font-size:13px;font-weight:600;color:var(--fg-1);margin-bottom:12px">Caching</h2>
        <p style="font-size:13px;color:var(--fg-2)">Lintasan can cache LLM responses to reduce costs and latency. Configure cache behavior in Settings. Cached responses are served instantly without calling upstream providers.</p>
      </section>
    </div>
  </div>
</div>
{{end}}
