<div
  x-data="routingPage()"
  x-init="rsFetchStats(); rsFetchCombos(); rsFetchLoadBalancer(); rsFetchAliases()"
  x-cloak
  class="fade-in"
>
  <!-- ════════════════════════════════════════════ -->
  <!--  Stats Bar                                      -->
  <!-- ════════════════════════════════════════════ -->
  <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin-bottom:24px">
    <div class="stat-card fade-in" style="animation-delay:0s">
      <div class="stat-label">Combos</div>
      <div class="stat-value" x-text="stats.combos ?? '—'">—</div>
    </div>
    <div class="stat-card fade-in" style="animation-delay:0.06s">
      <div class="stat-label">Strategy</div>
      <div class="stat-value" x-text="stats.strategy || '—'" style="font-size:16px">—</div>
    </div>
    <div class="stat-card fade-in" style="animation-delay:0.12s">
      <div class="stat-label">Aliases</div>
      <div class="stat-value" x-text="stats.aliases ?? '—'">—</div>
    </div>
  </div>

  <!-- ════════════════════════════════════════════ -->
  <!--  Top Bar                                       -->
  <!-- ════════════════════════════════════════════ -->
  <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:24px">
    <div>
      <h1 style="font-size:18px;font-weight:600;color:var(--fg-0);margin:0 0 4px">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="vertical-align:-3px;margin-right:6px;display:inline"><polyline points="16 3 21 3 21 8"/><line x1="4" y1="20" x2="21" y2="3"/><polyline points="21 16 21 21 16 21"/><line x1="15" y1="15" x2="21" y2="21"/><line x1="4" y1="4" x2="9" y2="9"/></svg>
        Routing
      </h1>
      <p style="font-size:13px;color:var(--fg-2);margin:0">Configure model routing, load balancing, and aliases.</p>
    </div>
    <button class="btn-primary" onclick="rs.openNewCombo()">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="display:inline"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="16"/><line x1="8" y1="12" x2="16" y2="12"/></svg>
      New Combo
    </button>
  </div>

  <!-- ════════════════════════════════════════════ -->
  <!--  SECTION 1: Combos                             -->
  <!-- ════════════════════════════════════════════ -->
  <div class="card" style="margin-bottom:24px">
    <h2 style="font-size:14px;font-weight:600;color:var(--fg-1);margin-bottom:16px;display:flex;align-items:center;gap:8px">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 3h5v5M4 20 21 3M21 16v5h-5M15 15l6 6M4 4l5 5"/></svg>
      Model Combos
    </h2>

    <table>
      <thead>
        <tr>
          <th>Name</th>
          <th>Description</th>
          <th>Strategy</th>
          <th>Models</th>
          <th>Sticky Limit</th>
          <th>Status</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <template x-if="combos === null">
          <tr>
            <td colspan="7" style="text-align:center;padding:32px 12px">
              <div class="spinner" style="margin:0 auto"></div>
            </td>
          </tr>
        </template>
        <template x-if="combos !== null && combos.length === 0">
          <tr>
            <td colspan="7" style="text-align:center;padding:0">
              <div class="empty-state">
                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="margin-bottom:8px;opacity:0.4"><polyline points="16 3 21 3 21 8"/><line x1="4" y1="20" x2="21" y2="3"/><polyline points="21 16 21 21 16 21"/><line x1="15" y1="15" x2="21" y2="21"/></svg>
                <p>No combos configured yet.</p>
                <p style="font-size:12px;color:var(--fg-3);margin-top:4px">Create a combo to route requests across multiple models.</p>
              </div>
            </td>
          </tr>
        </template>
        <template x-for="combo in combos" :key="combo.id">
          <tr>
            <td style="font-size:13px;font-weight:500" x-text="combo.name"></td>
            <td style="font-size:12px;color:var(--fg-2);max-width:200px">
              <span x-text="combo.description || '—'" style="overflow:hidden;text-overflow:ellipsis;white-space:nowrap;display:block"></span>
            </td>
            <td style="font-size:12px">
              <span class="status-badge badge-primary" x-text="combo.strategy || 'priority'" style="text-transform:capitalize"></span>
            </td>
            <td style="font-size:12px;color:var(--fg-2)">
              <span x-text="(combo.models || []).length || (combo.model_count || 0) || '0'"></span>
              <span style="color:var(--fg-3);margin-left:2px" x-text="(combo.models && combo.models.length === 1) ? 'model' : 'models'"></span>
            </td>
            <td style="font-size:12px;color:var(--fg-2)">
              <span x-text="combo.sticky_limit != null ? combo.sticky_limit : '—'"></span>
            </td>
            <td>
              <span
                class="status-badge"
                :class="combo.is_active !== false ? 'badge-success' : 'badge-error'"
                x-text="combo.is_active !== false ? 'Active' : 'Inactive'"
              ></span>
            </td>
            <td>
              <div style="display:flex;gap:4px">
                <button class="btn-small" onclick="rs.editCombo(this)">Edit</button>
                <button class="btn-small" style="color:var(--error)" onclick="rs.deleteCombo(this)">Delete</button>
              </div>
            </td>
          </tr>
        </template>
      </tbody>
    </table>
  </div>

  <!-- ════════════════════════════════════════════ -->
  <!--  SECTION 2: Load Balancer Strategy            -->
  <!-- ════════════════════════════════════════════ -->
  <div class="card" style="margin-bottom:24px">
    <h2 style="font-size:14px;font-weight:600;color:var(--fg-1);margin-bottom:16px;display:flex;align-items:center;gap:8px">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="2" x2="12" y2="6"/><line x1="12" y1="18" x2="12" y2="22"/><line x1="4.93" y1="4.93" x2="7.76" y2="7.76"/><line x1="16.24" y1="16.24" x2="19.07" y2="19.07"/><line x1="2" y1="12" x2="6" y2="12"/><line x1="18" y1="12" x2="22" y2="12"/><line x1="4.93" y1="19.07" x2="7.76" y2="16.24"/><line x1="16.24" y1="7.76" x2="19.07" y2="4.93"/></svg>
      Load Balancer
    </h2>
    <p style="font-size:12px;color:var(--fg-3);margin:0 0 16px">Select the strategy for distributing requests across connections and combo entries.</p>

    <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:12px">
      <!-- Priority -->
      <label
        style="display:flex;flex-direction:column;align-items:center;gap:8px;padding:16px 12px;border:2px solid;border-radius:var(--radius);cursor:pointer;transition:all var(--transition)"
        :style="lbStrategy === 'priority' ? 'border-color:var(--primary);background:var(--primary-light)' : 'border-color:var(--border);background:var(--bg-body)'"
        onclick="rs.setStrategy('priority')"
      >
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><line x1="12" y1="5" x2="12" y2="19"/><polyline points="19 12 12 19 5 12"/></svg>
        <span style="font-size:12px;font-weight:600;color:var(--fg-0)">Priority</span>
        <span style="font-size:10px;color:var(--fg-3);text-align:center">Try in order, stop on success</span>
      </label>

      <!-- Round-Robin -->
      <label
        style="display:flex;flex-direction:column;align-items:center;gap:8px;padding:16px 12px;border:2px solid;border-radius:var(--radius);cursor:pointer;transition:all var(--transition)"
        :style="lbStrategy === 'round-robin' ? 'border-color:var(--primary);background:var(--primary-light)' : 'border-color:var(--border);background:var(--bg-body)'"
        onclick="rs.setStrategy('round-robin')"
      >
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
        <span style="font-size:12px;font-weight:600;color:var(--fg-0)">Round-Robin</span>
        <span style="font-size:10px;color:var(--fg-3);text-align:center">Cycle through evenly</span>
      </label>

      <!-- Least-Connections -->
      <label
        style="display:flex;flex-direction:column;align-items:center;gap:8px;padding:16px 12px;border:2px solid;border-radius:var(--radius);cursor:pointer;transition:all var(--transition)"
        :style="lbStrategy === 'least-connections' ? 'border-color:var(--primary);background:var(--primary-light)' : 'border-color:var(--border);background:var(--bg-body)'"
        onclick="rs.setStrategy('least-connections')"
      >
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
        <span style="font-size:12px;font-weight:600;color:var(--fg-0)">Least-Conn</span>
        <span style="font-size:10px;color:var(--fg-3);text-align:center">Send to fewest active requests</span>
      </label>

      <!-- Latency-based -->
      <label
        style="display:flex;flex-direction:column;align-items:center;gap:8px;padding:16px 12px;border:2px solid;border-radius:var(--radius);cursor:pointer;transition:all var(--transition)"
        :style="lbStrategy === 'latency' ? 'border-color:var(--primary);background:var(--primary-light)' : 'border-color:var(--border);background:var(--bg-body)'"
        onclick="rs.setStrategy('latency')"
      >
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
        <span style="font-size:12px;font-weight:600;color:var(--fg-0)">Latency</span>
        <span style="font-size:10px;color:var(--fg-3);text-align:center">Pick the fastest provider</span>
      </label>
    </div>

    <!-- Save LB button -->
    <div style="display:flex;justify-content:flex-end;margin-top:16px;align-items:center;gap:12px">
      <span
        x-show="lbSaved"
        x-cloak
        style="font-size:13px;color:var(--success);display:flex;align-items:center;gap:4px"
      >
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
        Strategy saved
      </span>
      <button class="btn-secondary" onclick="rs.saveLoadBalancer()" :disabled="lbSaving">
        <span x-show="!lbSaving">Apply Strategy</span>
        <span x-show="lbSaving" x-cloak style="display:flex;align-items:center;gap:6px">
          <span class="spinner" style="width:14px;height:14px;border-width:2px"></span>
          Saving…
        </span>
      </button>
    </div>
  </div>

  <!-- ════════════════════════════════════════════ -->
  <!--  SECTION 3: Model Aliases                     -->
  <!-- ════════════════════════════════════════════ -->
  <div class="card" style="margin-bottom:24px">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:16px">
      <h2 style="font-size:14px;font-weight:600;color:var(--fg-1);margin:0;display:flex;align-items:center;gap:8px">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/></svg>
        Model Aliases
      </h2>
      <button class="btn-small" onclick="rs.openNewAlias()">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="16"/><line x1="8" y1="12" x2="16" y2="12"/></svg>
        Add Alias
      </button>
    </div>
    <p style="font-size:12px;color:var(--fg-3);margin:0 0 16px">Map short names to full model identifiers. E.g., <code style="font-family:var(--mono);font-size:11px;color:var(--primary);background:var(--primary-light);padding:1px 5px;border-radius:3px">gpt-4</code> → <code style="font-family:var(--mono);font-size:11px;color:var(--primary);background:var(--primary-light);padding:1px 5px;border-radius:3px">openai/gpt-4o</code></p>

    <table>
      <thead>
        <tr>
          <th>Alias</th>
          <th>Target Model</th>
          <th>Provider</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <template x-if="aliases === null">
          <tr>
            <td colspan="4" style="text-align:center;padding:32px 12px">
              <div class="spinner" style="margin:0 auto"></div>
            </td>
          </tr>
        </template>
        <template x-if="aliases !== null && aliases.length === 0">
          <tr>
            <td colspan="4" style="text-align:center;padding:0">
              <div class="empty-state">
                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="margin-bottom:8px;opacity:0.4"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/></svg>
                <p>No model aliases defined.</p>
                <p style="font-size:12px;color:var(--fg-3);margin-top:4px">Create aliases to simplify model names for your users.</p>
              </div>
            </td>
          </tr>
        </template>
        <template x-for="alias in aliases" :key="alias.id || alias.name">
          <tr>
            <td>
              <span class="mono" style="font-size:12px" x-text="alias.name || alias.alias"></span>
            </td>
            <td>
              <span class="mono" style="font-size:12px;color:var(--fg-0)" x-text="alias.target || alias.model"></span>
            </td>
            <td style="font-size:12px;color:var(--fg-2)" x-text="alias.provider || '—'"></td>
            <td>
              <div style="display:flex;gap:4px">
                <button class="btn-small" onclick="rs.editAlias(this)">Edit</button>
                <button class="btn-small" style="color:var(--error)" onclick="rs.deleteAlias(this)">Delete</button>
              </div>
            </td>
          </tr>
        </template>
      </tbody>
    </table>
  </div>

  <!-- ════════════════════════════════════════════ -->
  <!--  New / Edit Combo Modal                        -->
  <!-- ════════════════════════════════════════════ -->
  <template x-if="comboModal">
    <div>
      <div class="modal-backdrop" onclick="rs.closeComboModal()"></div>
      <div class="modal-panel" style="max-width:700px">
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:16px">
          <h2 style="font-size:16px;font-weight:600;color:var(--fg-0);margin:0" x-text="comboEditMode ? 'Edit Combo' : 'New Combo'"></h2>
          <button
            style="background:transparent;border:none;cursor:pointer;color:var(--fg-2);padding:4px;border-radius:var(--radius-sm);display:flex;align-items:center;line-height:1"
            onclick="rs.closeComboModal()"
          >
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
          </button>
        </div>

        <form onsubmit="event.preventDefault(); rs.saveCombo()">
          <input type="hidden" x-show="comboEditMode" x-model="comboEditId" />

          <!-- Combo Name -->
          <div style="margin-bottom:12px">
            <label class="label-st">Combo Name</label>
            <input type="text" class="input-field" placeholder="e.g., coding-team, cheap-fallback" x-model="comboForm.name" />
          </div>

          <!-- Description -->
          <div style="margin-bottom:12px">
            <label class="label-st">Description <span style="color:var(--fg-3);font-weight:400">(optional)</span></label>
            <input type="text" class="input-field" placeholder="e.g., Primary coding models with fallback" x-model="comboForm.description" />
          </div>

          <!-- Strategy -->
          <div style="margin-bottom:12px">
            <label class="label-st">Strategy</label>
            <select class="input-field" x-model="comboForm.strategy">
              <option value="priority">Priority (try in order)</option>
              <option value="round-robin">Round-Robin (cycle evenly)</option>
              <option value="least-connections">Least-Connections</option>
              <option value="latency">Latency-based</option>
            </select>
          </div>

          <!-- Sticky Limit -->
          <div style="margin-bottom:12px">
            <label class="label-st">Sticky Limit <span style="color:var(--fg-3);font-weight:400">(requests before advancing)</span></label>
            <input type="number" class="input-field" placeholder="3" x-model="comboForm.sticky_limit" min="1" max="100" />
          </div>

          <!-- Model Entries with Account Selectors -->
          <div style="margin-bottom:12px">
            <label class="label-st" style="display:flex;align-items:center;justify-content:space-between">
              <span>Model Entries</span>
              <button type="button" class="btn-small" onclick="rs.addModelEntry()" style="font-size:11px;padding:3px 8px">
                <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="16"/><line x1="8" y1="12" x2="16" y2="12"/></svg>
                Add
              </button>
            </label>

            <div style="display:flex;flex-direction:column;gap:8px">
              <template x-for="(entry, idx) in comboForm.models" :key="idx">
                <div style="display:flex;gap:8px;align-items:center;padding:8px;background:var(--bg-body);border:1px solid var(--border);border-radius:var(--radius-sm)">
                  <!-- Model name -->
                  <input
                    type="text"
                    class="input-field"
                    style="flex:2;margin:0"
                    placeholder="gpt-4o"
                    x-model="entry.model"
                  />
                  <!-- Account/Provider selector -->
                  <select class="input-field" style="flex:1;margin:0" x-model="entry.account">
                    <option value="">Any account</option>
                    <template x-for="conn in connections" :key="conn.id">
                      <option :value="conn.id" x-text="conn.name"></option>
                    </template>
                  </select>
                  <!-- Remove button -->
                  <button type="button" class="btn-small" style="color:var(--error);flex-shrink:0;padding:5px 8px" onclick="rs.removeModelEntry(this)">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                  </button>
                </div>
              </template>
            </div>

            <p x-show="comboForm.models.length === 0" style="font-size:11px;color:var(--fg-3);margin:8px 0 0">No models added. Click "Add" to include models in this combo.</p>
          </div>

          <!-- Active toggle -->
          <div style="margin-bottom:12px;display:flex;align-items:center;gap:8px">
            <label class="label-st" style="margin:0">Active</label>
            <input type="checkbox" x-model="comboForm.is_active" style="accent-color:var(--primary)" />
          </div>

          <!-- Actions -->
          <div style="display:flex;gap:8px;justify-content:flex-end;margin-top:20px;padding-top:16px;border-top:1px solid var(--border)">
            <button type="button" class="btn-secondary" onclick="rs.closeComboModal()">Cancel</button>
            <button type="submit" class="btn-primary" :disabled="!comboForm.name.trim() || comboSaving">
              <span x-show="!comboSaving" x-text="comboEditMode ? 'Update' : 'Create'"></span>
              <span x-show="comboSaving" x-cloak style="display:flex;align-items:center;gap:6px">
                <span class="spinner" style="width:14px;height:14px;border-width:2px"></span>
                Saving…
              </span>
            </button>
          </div>
        </form>
      </div>
    </div>
  </template>

  <!-- ════════════════════════════════════════════ -->
  <!--  New / Edit Alias Modal                       -->
  <!-- ════════════════════════════════════════════ -->
  <template x-if="aliasModal">
    <div>
      <div class="modal-backdrop" onclick="rs.closeAliasModal()"></div>
      <div class="modal-panel" style="max-width:500px">
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:16px">
          <h2 style="font-size:16px;font-weight:600;color:var(--fg-0);margin:0" x-text="aliasEditMode ? 'Edit Alias' : 'New Alias'"></h2>
          <button
            style="background:transparent;border:none;cursor:pointer;color:var(--fg-2);padding:4px;border-radius:var(--radius-sm);display:flex;align-items:center;line-height:1"
            onclick="rs.closeAliasModal()"
          >
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
          </button>
        </div>

        <form onsubmit="event.preventDefault(); rs.saveAlias()">
          <input type="hidden" x-show="aliasEditMode" x-model="aliasEditId" />

          <!-- Alias Name -->
          <div style="margin-bottom:12px">
            <label class="label-st">Alias Name <span style="color:var(--fg-3);font-weight:400">(short name)</span></label>
            <input type="text" class="input-field" placeholder="e.g., gpt-4, claude, cheap" x-model="aliasForm.name" />
          </div>

          <!-- Target Model -->
          <div style="margin-bottom:12px">
            <label class="label-st">Target Model <span style="color:var(--fg-3);font-weight:400">(full identifier)</span></label>
            <input type="text" class="input-field" placeholder="e.g., openai/gpt-4o, anthropic/claude-sonnet-4-20250514" x-model="aliasForm.target" />
          </div>

          <!-- Provider (optional) -->
          <div style="margin-bottom:12px">
            <label class="label-st">Provider <span style="color:var(--fg-3);font-weight:400">(optional, restricts to account)</span></label>
            <select class="input-field" x-model="aliasForm.provider">
              <option value="">Any provider</option>
              <template x-for="conn in connections" :key="conn.id">
                <option :value="conn.id" x-text="conn.name"></option>
              </template>
            </select>
          </div>

          <!-- Actions -->
          <div style="display:flex;gap:8px;justify-content:flex-end;margin-top:20px;padding-top:16px;border-top:1px solid var(--border)">
            <button type="button" class="btn-secondary" onclick="rs.closeAliasModal()">Cancel</button>
            <button type="submit" class="btn-primary" :disabled="!aliasForm.name.trim() || !aliasForm.target.trim() || aliasSaving">
              <span x-show="!aliasSaving" x-text="aliasEditMode ? 'Update' : 'Create'"></span>
              <span x-show="aliasSaving" x-cloak style="display:flex;align-items:center;gap:6px">
                <span class="spinner" style="width:14px;height:14px;border-width:2px"></span>
                Saving…
              </span>
            </button>
          </div>
        </form>
      </div>
    </div>
  </template>

  <!-- Toasts -->
  <div style="position:fixed;bottom:20px;right:20px;z-index:100;display:flex;flex-direction:column;gap:8px">
    <template x-for="(t, idx) in toasts" :key="idx">
      <div
        style="border-radius:var(--radius);padding:12px 20px;font-size:13px;font-weight:500;color:#fff;box-shadow:var(--shadow-md);animation:fadeInScale .3s ease-out;max-width:360px"
        :style="t.type === 'success' ? 'background:#166534' : 'background:#991b1b'"
        x-text="t.message"
        x-init="setTimeout(() => toasts.splice(idx, 1), 3500)"
      ></div>
    </template>
  </div>
</div>
