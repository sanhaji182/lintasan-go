{{define "pages/playground.gohtml"}}
<div x-data="{
  model: '',
  models: [],
  input: '',
  messages: [],
  streamText: '',
  loading: false,
  temp: 0.7,
  maxTok: 4096,
  sys: 'You are a helpful assistant.',
  single: false,
  showSettings: false,
  abortController: null,

  async init() {
    try {
      let r = await fetch('/api/connections');
      this.models = await r.json();
    } catch(e) {
      console.error('Failed to load models', e);
    }
  },

  async send() {
    if (!this.input.trim() || this.loading) return;
    let userMsg = this.input.trim();
    this.messages.push({ role: 'user', content: userMsg });
    this.input = '';
    this.streamText = '';
    this.loading = true;

    let payload = {
      model: this.model || (this.models[0] && this.models[0].id),
      messages: [{ role: 'system', content: this.sys }, ...this.messages],
      temperature: this.temp,
      max_tokens: this.maxTok,
      stream: true
    };

    this.abortController = new AbortController();

    try {
      let resp = await fetch('/api/v1/chat/completions', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
        signal: this.abortController.signal
      });

      if (!resp.ok) {
        let err = await resp.text();
        throw new Error(err || 'Request failed');
      }

      let reader = resp.body.getReader();
      let decoder = new TextDecoder();
      let buffer = '';
      let assistantMsg = '';

      while (true) {
        let { done, value } = await reader.read();
        if (done) break;
        buffer += decoder.decode(value, { stream: true });
        let lines = buffer.split('\n');
        buffer = lines.pop() || '';
        for (let line of lines) {
          line = line.trim();
          if (!line.startsWith('data: ')) continue;
          let data = line.slice(6);
          if (data === '[DONE]') continue;
          try {
            let json = JSON.parse(data);
            let delta = json.choices && json.choices[0] && json.choices[0].delta;
            if (delta && delta.content) {
              assistantMsg += delta.content;
              this.streamText = assistantMsg;
            }
          } catch(e) {}
        }
      }

      if (assistantMsg) {
        this.messages.push({ role: 'assistant', content: assistantMsg });
      }
    } catch(e) {
      if (e.name !== 'AbortError') {
        this.messages.push({ role: 'system', content: 'Error: ' + e.message, error: true });
      }
    }

    this.streamText = '';
    this.loading = false;
    this.abortController = null;
  },

  abort() {
    if (this.abortController) {
      this.abortController.abort();
      this.loading = false;
      this.streamText = '';
    }
  },

  copy(text) {
    navigator.clipboard.writeText(text).catch(() => {});
  },

  clear() {
    this.messages = [];
    this.streamText = '';
    this.input = '';
  }
}" x-init="init()">
  <div>
    <div>
      <h1>🧪 Playground</h1>
      <p>Test AI models directly from the dashboard.</p>
    </div>
    <div>
      <select x-model="model">
        <option value="">-- Select Model --</option>
        <template x-for="m in models" :key="m.id || m.name">
          <option x-bind:value="m.id || m.name" x-text="m.name || m.id"></option>
        </template>
      </select>
      <button class="btn btn-sm btn-secondary" x-on:click="showSettings = !showSettings" x-text="showSettings ? 'Hide Settings' : '⚙ Settings'"></button>
    </div>
  </div>

  <!-- Settings Panel -->
  <div class="card mb-4" x-show="showSettings">
    <div>
      <div>
        <label>System Prompt</label>
        <textarea x-model="sys" rows="3"></textarea>
      </div>
      <div>
        <div>
          <label>Temperature: <span x-text="temp"></span></label>
          <input type="range" x-model="temp" min="0" max="2" step="0.1">
        </div>
        <div>
          <label>Max Tokens</label>
          <input type="number" x-model="maxTok" min="1" max="131072">
        </div>
        <div>
          <label>
            <input type="checkbox" x-model="single">
            Single turn (no conversation history)
          </label>
        </div>
      </div>
    </div>
  </div>

  <!-- Chat Area -->
  <div class="- 380px)] card max-h-[calc(100vh mb-4 min-h-[400px] overflow-y-auto p-4" id="chat-messages">
    <template x-if="messages.length === 0 && !streamText">
      <div class="empty-state px-4 py-15">
        <div class="empty-state-icon">💬</div>
        <p>Send a message to start testing.</p>
      </div>
    </template>

    <template x-for="(msg, i) in messages" :key="i">
      <div
           x-bind:style="msg.role === 'user' ? 'text-align:right;' : ''">
        <div
             x-text="msg.error ? 'ERROR' : msg.role === 'user' ? 'You' : 'Assistant'"></div>
        <div
             x-bind:style="msg.error ?
               'background:#fee2e2; color:#991b1b;' :
               (msg.role === 'user' ?
                 'background:var(--color-primary); color:white;' :
                 'background:var(--color-bg-input); color:var(--color-fg-0);')"
             x-text="msg.content"></div>
        <button x-show="msg.role === 'assistant' && !msg.error"
                class="btn btn-ghost btn-sm ml-1 text-xs"
                x-on:click="copy(msg.content)">📋</button>
      </div>
    </template>

    <!-- Streaming text -->
    <template x-if="streamText">
      <div>
        <div>Assistant</div>
        <div
             x-text="streamText"></div>
        <span class="align-middle h-[12px] inline-block ml-1 spinner w-[12px]"></span>
      </div>
    </template>

    <!-- Loading indicator -->
    <div x-show="loading && !streamText">
      <div class="mx-auto spinner"></div>
    </div>
  </div>

  <!-- Input Area -->
  <div class="card px-4 py-3">
    <div>
      <textarea x-model="input" placeholder="Type your message..." rows="1"
                x-on:keydown.enter.prevent="if(!$event.shiftKey) { send(); }"
                x-on:input="$el.style.height = 'auto'; $el.style.height = Math.min($el.scrollHeight, 120) + 'px';"
                x-bind:disabled="loading"></textarea>
      <button x-show="!loading" class="btn btn-primary px-5 py-[10px]" x-on:click="send()" x-bind:disabled="!input.trim()">
        Send
      </button>
      <button x-show="loading" class="btn btn-danger px-5 py-[10px]" x-on:click="abort()">
        ⏹ Stop
      </button>
    </div>
    <div>
      <button class="btn btn-ghost btn-sm" x-on:click="clear()">🗑 Clear Chat</button>
    </div>
  </div>

  <!-- Marked.js (optional, loaded on demand) -->
  <script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>
</div>
{{end}}
