<div x-data="{
  model: '',
  models: [],
  input: '',
  messages: [],
  streamText: '',
  loading: false,
  temp: 0.7,
  maxTok: 4096,
  sys: 'You are a helpful assistant.',
  single: false,
  showSettings: false,
  abortController: null,

  async init() {
        window.playgroundScope = this;
      window.playgroundScope = this;
    try {
      let r = await fetch('/v1/models');
      let data = await r.json();
      this.models = data.data || [];
    } catch(e) {
      console.error('Failed to load models', e);
    }
  },

  async send() {
    if (!this.input.trim() || this.loading) return;
    let userMsg = this.input.trim();
    this.messages.push({ role: 'user', content: userMsg });
    this.input = '';
    this.streamText = '';
    this.loading = true;

    let payload = {
      model: this.model || (this.models[0] && this.models[0].id),
      messages: [{ role: 'system', content: this.sys }, ...this.messages],
      temperature: this.temp,
      max_tokens: this.maxTok,
      stream: true
    };

    this.abortController = new AbortController();

    try {
      let resp = await fetch('/api/v1/chat/completions', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
        signal: this.abortController.signal
      });

      if (!resp.ok) {
        let err = await resp.text();
        throw new Error(err || 'Request failed');
      }

      let reader = resp.body.getReader();
      let decoder = new TextDecoder();
      let buffer = '';
      let assistantMsg = '';

      while (true) {
        let { done, value } = await reader.read();
        if (done) break;
        buffer += decoder.decode(value, { stream: true });
        let lines = buffer.split('\n');
        buffer = lines.pop() || '';
        for (let line of lines) {
          line = line.trim();
          if (!line.startsWith('data: ')) continue;
          let data = line.slice(6).trim();
          if (data === '[DONE]') continue;
          try {
            let parsed = JSON.parse(data);
            let delta = parsed.choices?.[0]?.delta?.content || '';
            assistantMsg += delta;
            this.streamText = assistantMsg;
          } catch(e) {}
        }
      }

      if (assistantMsg) {
        this.messages.push({ role: 'assistant', content: assistantMsg });
      }
    } catch(e) {
      if (e.name !== 'AbortError') {
        this.messages.push({ role: 'system', content: 'Error: ' + e.message, error: true });
      }
    }

    this.streamText = '';
    this.loading = false;
    this.abortController = null;
  },

  abort() {
    if (this.abortController) {
      this.abortController.abort();
      this.loading = false;
      this.streamText = '';
    }
  },

  copy(text) {
    navigator.clipboard.writeText(text).catch(() => {});
  },

  clear() {
    this.messages = [];
    this.streamText = '';
    this.input = '';
  }
}" x-init="init(); window.playgroundScope = this">
  <style>
    .playground-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 20px;
    }
    .playground-title {
      font-size: 20px;
      font-weight: 700;
      color: var(--color-fg-0);
      display: flex;
      align-items: center;
      gap: 8px;
    }
    .playground-title svg {
      width: 24px;
      height: 24px;
      color: var(--color-primary);
    }
    .playground-subtitle {
      font-size: 13px;
      color: var(--color-fg-2);
      margin-top: 2px;
    }
    .playground-controls {
      display: flex;
      align-items: center;
      gap: 12px;
    }
    .settings-panel {
      margin-bottom: 16px;
    }
    .settings-title {
      font-size: 13px;
      font-weight: 600;
      color: var(--color-fg-1);
      margin-bottom: 12px;
    }
    .settings-grid {
      display: grid;
      grid-template-columns: 2fr 1fr;
      gap: 16px;
    }
    .settings-label {
      font-size: 11px;
      font-weight: 600;
      color: var(--color-fg-2);
      display: block;
      margin-bottom: 4px;
    }
    .chat-container {
      min-height: 400px;
      max-height: calc(100vh - 380px);
      overflow-y: auto;
      padding: 16px;
    }
    .empty-state {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      text-align: center;
      padding: 60px 20px;
      color: var(--color-fg-3);
    }
    .empty-state svg {
      width: 48px;
      height: 48px;
      margin-bottom: 16px;
      opacity: 0.4;
    }
    .empty-state p {
      font-size: 14px;
    }
    .message {
      margin-bottom: 12px;
    }
    .message-user {
      text-align: right;
    }
    .message-role {
      font-size: 11px;
      font-weight: 600;
      margin-bottom: 4px;
      color: var(--color-fg-2);
    }
    .message-bubble {
      display: inline-block;
      border-radius: var(--radius);
      padding: 12px;
      max-width: 80%;
      font-size: 13px;
      line-height: 1.5;
    }
    .message-bubble-user {
      background: var(--color-primary);
      color: #fff;
    }
    .message-bubble-assistant {
      background: var(--color-bg-input);
      color: var(--color-fg-0);
    }
    .message-bubble-error {
      background: var(--color-danger-light);
      color: #991b1b;
    }
    .message-actions {
      margin-top: 4px;
    }
    .input-area {
      padding: 12px 16px;
    }
    .input-row {
      display: flex;
      gap: 12px;
      align-items: flex-end;
    }
    .input-textarea {
      flex: 1;
      resize: none;
      min-height: 44px;
      max-height: 120px;
    }
    .input-actions {
      margin-top: 8px;
    }
  </style>

  <div class="playground-header">
    <div>
      <h1 class="playground-title">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
        </svg>
        Playground
      </h1>
      <p class="playground-subtitle">Test AI models directly from the dashboard.</p>
    </div>
    <div class="playground-controls">
      <select x-model="model" class="form-select" style="width: auto; min-width: 180px;">
        <option value="">-- Select Model --</option>
        <template x-for="m in models" :key="m.id || m.name">
          <option :value="m.id || m.name" x-text="m.name || m.id"></option>
        </template>
      </select>
      <button class="btn btn-secondary" onclick="window.playgroundScope.showSettings = !showSettings">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="12" cy="12" r="3"/>
          <path d="M19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 010 2.83 2 2 0 01-2.83 0l-.06-.06a1.65 1.65 0 00-1.82-.33 1.65 1.65 0 00-1 1.51V21a2 2 0 01-2 2 2 2 0 01-2-2v-.09A1.65 1.65 0 009 19.4a1.65 1.65 0 00-1.82.33l-.06.06a2 2 0 01-2.83 0 2 2 0 010-2.83l.06-.06a1.65 1.65 0 00.33-1.82 1.65 1.65 0 00-1.51-1H3a2 2 0 01-2-2 2 2 0 012-2h.09A1.65 1.65 0 004.6 9a1.65 1.65 0 00-.33-1.82l-.06-.06a2 2 0 010-2.83 2 2 0 012.83 0l.06.06a1.65 1.65 0 001.82.33H9a1.65 1.65 0 001-1.51V3a2 2 0 012-2 2 2 0 012 2v.09a1.65 1.65 0 001 1.51 1.65 1.65 0 001.82-.33l.06-.06a2 2 0 012.83 0 2 2 0 010 2.83l-.06.06a1.65 1.65 0 00-.33 1.82V9a1.65 1.65 0 001.51 1H21a2 2 0 012 2 2 2 0 01-2 2h-.09a1.65 1.65 0 00-1.51 1z"/>
        </svg>
        <span x-text="showSettings ? 'Hide Settings' : 'Settings'"></span>
      </button>
    </div>
  </div>

  <!-- Settings Panel -->
  <div class="card settings-panel" x-show="showSettings">
    <h2 class="settings-title">Settings</h2>
    <div class="settings-grid">
      <div>
        <label class="settings-label">System Prompt</label>
        <textarea x-model="sys" rows="3" style="margin-top: 4px;"></textarea>
      </div>
      <div>
        <div style="margin-bottom: 12px;">
          <label class="settings-label">Temperature: <span x-text="temp"></span></label>
          <input type="range" x-model="temp" min="0" max="2" step="0.1" style="margin-top: 4px; width: 100%;">
        </div>
        <div style="margin-bottom: 12px;">
          <label class="settings-label">Max Tokens</label>
          <input type="number" x-model="maxTok" min="1" max="131072" style="margin-top: 4px;">
        </div>
        <div>
          <label style="display: flex; align-items: center; gap: 8px; font-size: 12px; color: var(--color-fg-2); cursor: pointer;">
            <input type="checkbox" x-model="single" style="width: auto;">
            Single turn (no history)
          </label>
        </div>
      </div>
    </div>
  </div>

  <!-- Chat Area -->
  <div class="card chat-container" id="chat-messages">
    <template x-if="messages.length === 0 && !streamText">
      <div class="empty-state">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
        </svg>
        <p>Send a message to start testing.</p>
      </div>
    </template>

    <template x-for="(msg, i) in messages" :key="i">
      <div class="message" :class="msg.role === 'user' ? 'message-user' : ''">
        <div class="message-role" x-text="msg.error ? 'ERROR' : msg.role === 'user' ? 'You' : 'Assistant'"></div>
        <div class="message-bubble"
             :class="msg.error ? 'message-bubble-error' : (msg.role === 'user' ? 'message-bubble-user' : 'message-bubble-assistant')"
             x-text="msg.content"></div>
        <div class="message-actions" x-show="msg.role === 'assistant' && !msg.error">
          <button class="btn btn-ghost btn-sm"
                  onclick="window.playgroundScope.copy(msg.content)"
                  title="Copy to clipboard">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <rect x="9" y="9" width="13" height="13" rx="2" ry="2"/>
              <path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/>
            </svg>
          </button>
        </div>
      </div>
    </template>

    <!-- Streaming text -->
    <template x-if="streamText">
      <div class="message">
        <div class="message-role">Assistant</div>
        <div class="message-bubble message-bubble-assistant" x-text="streamText"></div>
        <span class="spinner" style="width: 12px; height: 12px; margin-left: 8px; vertical-align: middle;"></span>
      </div>
    </template>

    <!-- Loading indicator -->
    <div x-show="loading && !streamText" style="text-align: center; padding: 16px 0;">
      <div class="spinner" style="margin: 0 auto;"></div>
    </div>
  </div>

  <!-- Input Area -->
  <div class="card input-area">
    <div class="input-row">
      <textarea x-model="input" placeholder="Type your message..." rows="1"
              onkeydown="if(event.key==='Enter'&&!event.shiftKey){event.preventDefault();window.playgroundScope.send()}"
              oninput="this.style.height='auto';this.style.height=Math.min(this.scrollHeight,300)+'px'"
                :disabled="loading" class="input-textarea"></textarea>
      <button x-show="!loading" class="btn btn-primary" style="padding: 10px 20px;" onclick="window.playgroundScope.send()" :disabled="!input.trim()">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="22" y1="2" x2="11" y2="13"/>
          <polygon points="22 2 15 22 11 13 2 9 22 2"/>
        </svg>
        Send
      </button>
      <button x-show="loading" class="btn btn-danger" style="padding: 10px 20px;" onclick="window.playgroundScope.abort()">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
        </svg>
        Stop
      </button>
    </div>
    <div class="input-actions">
      <button class="btn btn-ghost btn-sm" onclick="window.playgroundScope.clear()">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <polyline points="3 6 5 6 21 6"/>
          <path d="M19 6v14a2 2 0 01-2 2H7a2 2 0 01-2-2V6m3 0V4a2 2 0 012-2h4a2 2 0 012 2v2"/>
          <line x1="10" y1="11" x2="10" y2="17"/>
          <line x1="14" y1="11" x2="14" y2="17"/>
        </svg>
        Clear Chat
      </button>
    </div>
  </div>
</div>
