<div x-data="{
  model: '',
  models: [],
  input: '',
  messages: [],
  streamText: '',
  loading: false,
  temp: 0.7,
  maxTok: 4096,
  sys: '',
  single: false,
  showSettings: false,
  abortController: null,
  copied: null,

  get modelGroups() {
    let groups = {};
    this.models.forEach(m => {
      let g = m.owned_by || 'Other';
      if (!groups[g]) groups[g] = [];
      groups[g].push(m);
    });
    return groups;
  },

  async init() {
    window.playgroundScope = this;
    try {
      let r = await fetch('/v1/models');
      let data = await r.json();
      this.models = data.data || [];
      this.model = '';
    } catch(e) { console.error('Failed to load models', e); }
  },

  async send() {
    if (!this.input.trim() || this.loading) return;
    let userMsg = this.input.trim();
    this.messages.push({ role: 'user', content: userMsg });
    this.input = '';
    this.streamText = '';
    this.loading = true;

    let selectedModel = this.model || (this.models[0] && this.models[0].id);
    if (!selectedModel) { this.loading = false; return; }

    let reqMessages = this.sys ? [{ role: 'system', content: this.sys }] : [];
    if (this.single) {
      reqMessages.push({ role: 'user', content: userMsg });
    } else {
      reqMessages.push(...this.messages.map(m => ({ role: m.role, content: m.content })));
    }

    let payload = {
      model: selectedModel,
      messages: reqMessages,
      temperature: this.temp,
      max_tokens: this.maxTok,
      stream: true
    };

    let startTime = Date.now();
    this.abortController = new AbortController();

    try {
      let resp = await fetch('/api/v1/chat/completions', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
        signal: this.abortController.signal
      });

      if (!resp.ok) {
        let errText = await resp.text();
        let errMsg = 'Request failed';
        try { let j = JSON.parse(errText); errMsg = j.error?.message || errMsg; } catch(e) {}
        this.messages.push({ role: 'assistant', content: 'Error: ' + errMsg, error: true });
        this.loading = false;
        return;
      }

      let provider = resp.headers.get('X-Provider') || '';
      let reader = resp.body.getReader();
      let decoder = new TextDecoder();
      let buffer = '';
      let assistantMsg = '';

      while (true) {
        let { done, value } = await reader.read();
        if (done) break;
        buffer += decoder.decode(value, { stream: true });
        let lines = buffer.split('\n');
        buffer = lines.pop() || '';
        for (let line of lines) {
          line = line.trim();
          if (!line.startsWith('data: ')) continue;
          let data = line.slice(6).trim();
          if (data === '[DONE]') continue;
          try {
            let parsed = JSON.parse(data);
            let delta = parsed.choices?.[0]?.delta?.content || '';
            assistantMsg += delta;
            this.streamText = assistantMsg;
          } catch(e) {}
        }
      }

      let latency = Date.now() - startTime;
      if (assistantMsg) {
        this.messages.push({ role: 'assistant', content: assistantMsg, provider, latency });
      }
    } catch(e) {
      if (e.name !== 'AbortError') {
        this.messages.push({ role: 'assistant', content: 'Network error: ' + e.message, error: true });
      }
    }

    this.streamText = '';
    this.loading = false;
    this.abortController = null;
  },

  abort() {
    if (this.abortController) {
      this.abortController.abort();
      this.loading = false;
      this.streamText = '';
    }
  },

  copy(text, idx) {
    navigator.clipboard.writeText(text).then(() => {
      this.copied = idx;
      setTimeout(() => { this.copied = null; }, 2000);
    }).catch(() => {});
  },

  clear() {
    this.messages = [];
    this.streamText = '';
    this.input = '';
  },

  useSuggestion(text) {
    this.input = text;
    this.$refs.inputEl.focus();
  }
}" x-init="init()" x-cloak>
  <style>
    .pg-wrap{display:flex;flex-direction:column;height:calc(100vh - 140px);gap:12px}
    .pg-hdr{display:flex;align-items:center;gap:12px;padding:10px 16px;background:var(--bg-card);border:1px solid var(--border);border-radius:var(--radius)}
    .pg-hdr select{width:auto;min-width:200px;padding:8px 12px;background:var(--bg-body);border:1px solid var(--border);border-radius:var(--radius-sm);font-size:13px;color:var(--fg-0);outline:none;cursor:pointer}
    .pg-hdr select:focus{border-color:var(--primary)}
    .pg-hdr select optgroup{font-weight:600;color:var(--fg-3);font-size:11px;text-transform:uppercase;letter-spacing:0.5px}
    .pg-hdr select option{font-size:13px;color:var(--fg-0);font-weight:400;text-transform:none;letter-spacing:0}
    .pg-hdr-actions{display:flex;gap:6px;margin-left:auto}
    .pg-btn-icon{width:36px;height:36px;display:flex;align-items:center;justify-content:center;background:var(--bg-body);border:1px solid var(--border);border-radius:var(--radius-sm);cursor:pointer;color:var(--fg-2);transition:all var(--transition)}
    .pg-btn-icon:hover{color:var(--fg-0);border-color:var(--fg-3)}
    .pg-btn-icon.active{color:var(--primary);border-color:var(--primary);background:var(--primary-light)}

    .pg-settings{display:grid;grid-template-columns:1fr 1fr;gap:16px;padding:14px 16px;background:var(--bg-card);border:1px solid var(--border);border-radius:var(--radius)}
    .pg-settings-left{display:flex;flex-direction:column;gap:12px}
    .pg-settings-right{display:flex;flex-direction:column;gap:12px}
    .pg-slider-row{display:flex;align-items:center;gap:10px}
    .pg-slider-row input[type=range]{flex:1;accent-color:var(--primary)}
    .pg-slider-val{font-size:12px;font-weight:600;color:var(--fg-0);min-width:32px;text-align:right;font-family:var(--mono)}
    .pg-label{font-size:11px;font-weight:600;color:var(--fg-2);display:block;margin-bottom:4px;text-transform:uppercase;letter-spacing:0.5px}
    .pg-input{width:100%;padding:7px 10px;background:var(--bg-body);border:1px solid var(--border);border-radius:var(--radius-sm);font-size:12px;color:var(--fg-0);outline:none;transition:border-color 0.15s;box-sizing:border-box}
    .pg-input:focus{border-color:var(--primary)}
    .pg-check-row{display:flex;align-items:center;gap:8px}
    .pg-check-row input[type=checkbox]{width:16px;height:16px;accent-color:var(--primary);cursor:pointer}
    .pg-check-label{font-size:12px;color:var(--fg-1);cursor:pointer}
    .pg-check-hint{font-size:11px;color:var(--fg-3)}

    .pg-chat{flex:1;overflow-y:auto;padding:20px;background:var(--bg-body);border:1px solid var(--border);border-radius:var(--radius)}

    .pg-empty{display:flex;flex-direction:column;align-items:center;justify-content:center;height:100%;text-align:center;gap:12px}
    .pg-empty-icon{width:56px;height:56px;border-radius:16px;background:var(--primary-light);display:flex;align-items:center;justify-content:center;color:var(--primary)}
    .pg-empty-title{font-size:15px;font-weight:600;color:var(--fg-0)}
    .pg-empty-sub{font-size:13px;color:var(--fg-3)}
    .pg-chips{display:flex;gap:8px;flex-wrap:wrap;justify-content:center;margin-top:4px}
    .pg-chip{font-size:12px;padding:7px 14px;background:var(--bg-card);border:1px solid var(--border);border-radius:20px;cursor:pointer;color:var(--fg-1);transition:all var(--transition)}
    .pg-chip:hover{background:var(--primary-light);color:var(--primary);border-color:var(--primary)}

    .pg-msg{display:flex;gap:10px;margin-bottom:14px}
    .pg-msg-user{flex-direction:row-reverse}
    .pg-avatar{width:30px;height:30px;border-radius:50%;display:flex;align-items:center;justify-content:center;flex-shrink:0}
    .pg-avatar-user{background:var(--primary);color:#fff}
    .pg-avatar-assistant{background:var(--bg-card);border:1px solid var(--border);color:var(--fg-2)}
    .pg-bubble-wrap{max-width:75%;min-width:60px;position:relative}
    .pg-bubble{padding:10px 14px;font-size:13px;line-height:1.6;white-space:pre-wrap;word-break:break-word;position:relative}
    .pg-bubble-user{border-radius:16px 16px 4px 16px;background:var(--primary);color:#fff}
    .pg-bubble-assistant{border-radius:16px 16px 16px 4px;background:var(--bg-card);border:1px solid var(--border);color:var(--fg-0)}
    .pg-bubble-error{border-radius:16px 16px 16px 4px;background:var(--error-light);border:1px solid var(--error);color:#991b1b}
    .pg-bubble code{background:var(--bg-body);padding:1px 5px;border-radius:4px;font-size:12px;font-family:var(--mono);border:1px solid var(--border)}
    .pg-bubble-user code{background:rgba(255,255,255,0.15);border-color:rgba(255,255,255,0.2);color:#fff}
    .pg-bubble pre{background:#1e1e2e;color:#cdd6f4;padding:12px 14px;border-radius:8px;font-size:12px;font-family:var(--mono);overflow-x:auto;margin:8px 0;line-height:1.5;border:1px solid #313244}
    .pg-bubble pre .lang-tag{font-size:10px;color:#6c7086;margin-bottom:4px;text-transform:uppercase;display:block}
    .pg-copy-btn{position:absolute;top:6px;right:6px;background:var(--bg-body);border:1px solid var(--border);border-radius:4px;padding:2px 7px;font-size:10px;cursor:pointer;color:var(--fg-3);transition:all var(--transition);opacity:0;line-height:1.5}
    .pg-bubble-wrap:hover .pg-copy-btn{opacity:1}
    .pg-copy-btn:hover{color:var(--fg-0);border-color:var(--fg-3)}
    .pg-copy-btn.done{color:var(--success);border-color:var(--success)}
    .pg-meta{display:flex;gap:8px;margin-top:4px;font-size:11px;color:var(--fg-3);padding-left:4px}
    .pg-meta-badge{padding:1px 6px;border-radius:4px;font-weight:500;font-size:10px}
    .pg-meta-provider{background:var(--success-light);color:var(--success)}
    .pg-stream-indicator{display:flex;align-items:center;gap:6px;margin-top:4px;font-size:11px;color:var(--primary);padding-left:4px}
    .pg-stream-dot{width:6px;height:6px;border-radius:50%;background:var(--primary);animation:pulse 1.5s ease-in-out infinite}

    .pg-input-wrap{padding:12px 14px;background:var(--bg-card);border:1px solid var(--border);border-radius:var(--radius)}
    .pg-input-row{display:flex;gap:10px;align-items:flex-end}
    .pg-input-row textarea{flex:1;resize:none;min-height:40px;max-height:120px;padding:10px 14px;background:var(--bg-body);border:1px solid var(--border);border-radius:var(--radius-sm);font-size:13px;color:var(--fg-0);outline:none;line-height:1.5;font-family:inherit;transition:border-color 0.15s;box-sizing:border-box}
    .pg-input-row textarea:focus{border-color:var(--primary)}
    .pg-input-row textarea::placeholder{color:var(--fg-3)}
    .pg-send-btn{width:42px;height:42px;display:flex;align-items:center;justify-content:center;background:var(--primary);border:none;border-radius:var(--radius-sm);cursor:pointer;color:#fff;flex-shrink:0;transition:all var(--transition)}
    .pg-send-btn:hover{background:var(--primary-hover);box-shadow:0 4px 12px var(--primary-glow)}
    .pg-send-btn:disabled{opacity:0.35;cursor:not-allowed}
    .pg-stop-btn{display:flex;align-items:center;gap:6px;padding:8px 16px;background:transparent;border:1px solid var(--error);border-radius:var(--radius-sm);cursor:pointer;color:var(--error);font-size:13px;font-weight:500;flex-shrink:0;transition:all var(--transition)}
    .pg-stop-btn:hover{background:var(--error-light)}
    .pg-footer{display:flex;justify-content:space-between;margin-top:6px;font-size:11px;color:var(--fg-3)}
  </style>

  <!-- Header -->
  <div class="pg-hdr">
    <select x-model="model">
      <option value="">-- Select a model --</option>
      <template x-if="models.length === 0">
        <option value="" disabled>No models available</option>
      </template>
      <template x-for="(gModels, group) in modelGroups" :key="group">
        <optgroup :label="group">
          <template x-for="m in gModels" :key="m.id">
            <option :value="m.id" x-text="m.id"></option>
          </template>
        </optgroup>
      </template>
    </select>
    <div class="pg-hdr-actions">
      <button class="pg-btn-icon" :class="{ active: showSettings }" @click="showSettings = !showSettings" title="Settings">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 010 2.83 2 2 0 01-2.83 0l-.06-.06a1.65 1.65 0 00-1.82-.33 1.65 1.65 0 00-1 1.51V21a2 2 0 01-2 2 2 2 0 01-2-2v-.09A1.65 1.65 0 009 19.4a1.65 1.65 0 00-1.82.33l-.06.06a2 2 0 01-2.83 0 2 2 0 010-2.83l.06-.06A1.65 1.65 0 004.68 15a1.65 1.65 0 00-1.51-1H3a2 2 0 01-2-2 2 2 0 012-2h.09A1.65 1.65 0 004.6 9a1.65 1.65 0 00-.33-1.82l-.06-.06a2 2 0 010-2.83 2 2 0 012.83 0l.06.06A1.65 1.65 0 009 4.68a1.65 1.65 0 001-1.51V3a2 2 0 012-2 2 2 0 012 2v.09a1.65 1.65 0 001 1.51 1.65 1.65 0 001.82-.33l.06-.06a2 2 0 012.83 0 2 2 0 010 2.83l-.06.06A1.65 1.65 0 0019.4 9a1.65 1.65 0 001.51 1H21a2 2 0 012 2 2 2 0 01-2 2h-.09a1.65 1.65 0 00-1.51 1z"/></svg>
      </button>
      <button class="pg-btn-icon" @click="clear()" title="Clear chat">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 01-2 2H7a2 2 0 01-2-2V6m3 0V4a2 2 0 012-2h4a2 2 0 012 2v2"/></svg>
      </button>
    </div>
  </div>

  <!-- Settings Panel -->
  <div class="pg-settings" x-show="showSettings" x-transition>
    <div class="pg-settings-left">
      <div>
        <label class="pg-label">System Prompt</label>
        <textarea x-model="sys" class="pg-input" rows="3" style="resize:vertical;min-height:50px;font-family:var(--mono);font-size:12px" placeholder="You are a helpful assistant..."></textarea>
      </div>
    </div>
    <div class="pg-settings-right">
      <div>
        <label class="pg-label">Temperature: <span x-text="temp" class="pg-slider-val" style="display:inline"></span></label>
        <div class="pg-slider-row">
          <input type="range" x-model="temp" min="0" max="2" step="0.1">
        </div>
      </div>
      <div>
        <label class="pg-label">Max Tokens</label>
        <input type="number" x-model="maxTok" min="1" max="128000" class="pg-input" style="width:120px">
      </div>
      <div>
        <div class="pg-check-row" style="margin-bottom:4px">
          <input type="checkbox" x-model="single" id="pg-single">
          <label class="pg-check-label" for="pg-single">Single-turn mode</label>
        </div>
        <span class="pg-check-hint" x-text="single ? 'Each message sent independently (cache-friendly)' : 'Full conversation history sent (multi-turn)'"></span>
      </div>
    </div>
  </div>

  <!-- Chat Area -->
  <div class="pg-chat" id="pg-chat-scroll" x-ref="chatEl">
    <!-- Empty State -->
    <template x-if="messages.length === 0 && !streamText">
      <div class="pg-empty">
        <div class="pg-empty-icon">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>
        </div>
        <div>
          <p class="pg-empty-title">Playground</p>
          <p class="pg-empty-sub">Test any model. Select one above and start chatting.</p>
        </div>
        <div class="pg-chips">
          <button class="pg-chip" @click="useSuggestion('Hello! Who are you?')">Hello! Who are you?</button>
          <button class="pg-chip" @click="useSuggestion('Write a haiku about AI')">Write a haiku about AI</button>
          <button class="pg-chip" @click="useSuggestion('Explain quantum computing in simple terms')">Explain quantum computing simply</button>
          <button class="pg-chip" @click="useSuggestion('Write a Python function to reverse a string')">Reverse a string in Python</button>
        </div>
      </div>
    </template>

    <!-- Messages -->
    <template x-for="(msg, i) in messages" :key="i">
      <div class="pg-msg" :class="msg.role === 'user' ? 'pg-msg-user' : ''">
        <!-- Avatar -->
        <div class="pg-avatar" :class="msg.role === 'user' ? 'pg-avatar-user' : 'pg-avatar-assistant'">
          <template x-if="msg.role === 'user'">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
          </template>
          <template x-if="msg.role !== 'user'">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="10" rx="2"/><circle cx="12" cy="5" r="2"/><path d="M12 7v4"/><line x1="8" y1="16" x2="8" y2="16"/><line x1="16" y1="16" x2="16" y2="16"/></svg>
          </template>
        </div>

        <!-- Bubble -->
        <div class="pg-bubble-wrap">
          <div class="pg-bubble" :class="msg.error ? 'pg-bubble-error' : (msg.role === 'user' ? 'pg-bubble-user' : 'pg-bubble-assistant')">
            <span x-html="formatContent(msg.content, msg.role === 'user')"></span>

            <!-- Copy button for non-user, non-streaming messages -->
            <button x-show="msg.role !== 'user' && !msg.streaming"
                    class="pg-copy-btn" :class="{ done: copied === i }"
                    @click="copy(msg.content, i)"
                    x-text="copied === i ? '\u2713 Copied' : 'Copy'"></button>
          </div>

          <!-- Meta info for assistant -->
          <div class="pg-meta" x-show="msg.role !== 'user' && !msg.error && !msg.streaming">
            <span x-show="msg.provider" class="pg-meta-badge pg-meta-provider" x-text="msg.provider"></span>
            <span x-show="msg.latency" x-text="(msg.latency / 1000).toFixed(1) + 's'"></span>
          </div>
        </div>
      </div>
    </template>

    <!-- Streaming message -->
    <template x-if="streamText">
      <div class="pg-msg">
        <div class="pg-avatar pg-avatar-assistant">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="10" rx="2"/><circle cx="12" cy="5" r="2"/><path d="M12 7v4"/><line x1="8" y1="16" x2="8" y2="16"/><line x1="16" y1="16" x2="16" y2="16"/></svg>
        </div>
        <div class="pg-bubble-wrap">
          <div class="pg-bubble pg-bubble-assistant">
            <span x-html="formatContent(streamText, false)"></span>
          </div>
          <div class="pg-stream-indicator">
            <span class="pg-stream-dot"></span> Streaming...
          </div>
        </div>
      </div>
    </template>

    <!-- Loading dots (before first token) -->
    <div x-show="loading && !streamText" style="display:flex;gap:10px;align-items:center;padding:8px 0">
      <div class="pg-avatar pg-avatar-assistant">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="10" rx="2"/><circle cx="12" cy="5" r="2"/><path d="M12 7v4"/><line x1="8" y1="16" x2="8" y2="16"/><line x1="16" y1="16" x2="16" y2="16"/></svg>
      </div>
      <div style="padding:10px 14px;background:var(--bg-card);border:1px solid var(--border);border-radius:var(--radius-sm)">
        <div style="display:flex;gap:5px">
          <span style="width:6px;height:6px;border-radius:50%;background:var(--fg-3);animation:pulse 1.2s ease-in-out infinite"></span>
          <span style="width:6px;height:6px;border-radius:50%;background:var(--fg-3);animation:pulse 1.2s ease-in-out 0.2s infinite"></span>
          <span style="width:6px;height:6px;border-radius:50%;background:var(--fg-3);animation:pulse 1.2s ease-in-out 0.4s infinite"></span>
        </div>
      </div>
    </div>
  </div>

  <!-- Input Area -->
  <div class="pg-input-wrap">
    <form class="pg-input-row" @submit.prevent="send()">
      <textarea
        x-ref="inputEl"
        x-model="input"
        placeholder="Type a message... (Enter to send, Shift+Enter for newline)"
        rows="1"
        :disabled="loading"
        @keydown.enter.prevent="!$event.shiftKey && send()"
        @input="$el.style.height='auto'; $el.style.height=Math.min($el.scrollHeight,120)+'px'"
      ></textarea>

      <!-- Send button -->
      <button x-show="!loading" class="pg-send-btn" type="submit" :disabled="!input.trim()" title="Send">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
      </button>

      <!-- Stop button -->
      <button x-show="loading" class="pg-stop-btn" type="button" @click="abort()">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><rect x="3" y="3" width="18" height="18" rx="3" ry="3"/></svg>
        Stop
      </button>
    </form>
    <div class="pg-footer">
      <span x-text="model || 'No model selected'"></span>
      <span x-text="'temp: ' + temp + ' | max: ' + maxTok.toLocaleString()"></span>
    </div>
  </div>
</div>
